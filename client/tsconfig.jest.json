{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": false,
    "types": ["jest", "vite/client"],
    "noEmit": true
  },
  "include": ["src", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
